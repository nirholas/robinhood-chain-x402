{
  "name": "hood402-facilitator",
  "version": "0.1.0",
  "description": "Self-hostable x402 facilitator for USDG on Robinhood Chain — verify + settle endpoints, idempotent SQLite ledger, metrics. Built on the hood402 protocol package.",
  "keywords": ["x402", "facilitator", "robinhood-chain", "usdg", "eip-3009"],
  "license": "MIT",
  "author": "nirholas (https://x.com/nichxbt)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "hood402-facilitator": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node --no-warnings=ExperimentalWarning dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "hood402": "file:..",
    "viem": "^2.55.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
